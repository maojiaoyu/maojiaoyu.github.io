{
  "name": "astro-theme-iris",
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "version": "4.1.4",
  "scripts": {
    "dev": "astro dev",
    "dev:check": "astro check --watch & astro dev",
    "build": "astro-pure check && astro check && astro build",
    "preview": "astro preview",
    "sync": "astro sync",
    "check": "astro check",
    "astro": "astro",
    "pure": "astro-pure",
    "format": "prettier --write  '**/*.{js,jsx,ts,tsx,md,mdx,astro}'",
    "lint": "eslint --fix 'src/**/*.{js,ts,jsx,tsx,astro}'",
    "yijiansilian": "bun lint && bun sync && bun check && bun format",
    "clean": "rm -rf .astro .vercel dist",
    "cache:avatars": "tsx preset/scripts/cacheAvatars.ts"
  },
  "dependencies": {
    "@astrojs/check": "0.9.8",
    "@astrojs/compiler-rs": "^0.1.8",
    "@astrojs/markdown-remark": "^7.1.0",
    "@astrojs/rss": "4.0.18",
    "@astrojs/vercel": "10.0.4",
    "@myriaddreamin/typst-ts-node-compiler": "^0.6.1-rc5",
    "@myriaddreamin/typst-ts-renderer": "^0.6.1-rc5",
    "@unocss/astro": "^66.6.8",
    "@unocss/preset-typography": "^66.6.8",
    "@unocss/reset": "^66.6.8",
    "@waline/client": "^3.13.0",
    "astro": "6.1.8",
    "astro-mermaid": "^1.2.0",
    "astro-pure": "1.4.6",
    "astro-typst": "^0.12.3",
    "d3": "^7.9.0",
    "flexsearch": "^0.8.212",
    "hastscript": "^9.0.1",
    "katex": "^0.16.45",
    "mermaid": "^11.12.2",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "sharp": "^0.34.5",
    "tippy.js": "^6.3.7",
    "typescript": "^6.0.3",
    "unist-util-visit": "^5.0.0",
    "unocss": "^66.6.8"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@shikijs/core": "^4.0.2",
    "@shikijs/types": "^4.0.2",
    "@types/d3": "^7.4.3",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/tippy.js": "^6.3.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^10.2.1",
    "eslint-plugin-astro": "^1.7.0",
    "lightningcss": "^1.31.1",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "rehype": "^13.0.2",
    "rehype-stringify": "^10.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "shiki": "^4.0.2",
    "ultrahtml": "^1.6.0",
    "unified": "^11.0.5",
    "vfile": "^6.0.3"
