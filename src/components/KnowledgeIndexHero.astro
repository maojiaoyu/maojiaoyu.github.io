---
import type { IconsType } from 'astro-pure/types'
import { Icon } from 'astro-pure/user'

interface Stat {
  label: string
  value: number | string
}

interface Props {
  icon: IconsType
  eyebrow: string
  title: string
  description: string
  stats: Stat[]
  statsLabel: string
  symbol: string
}

const { icon, eyebrow, title, description, stats, statsLabel, symbol } = Astro.props
---

<header id='content-header' class='index-hero animate' style={`--hero-symbol:"${symbol}"`}>
  <div class='index-hero__copy'>
    <span class='index-hero__eyebrow'>
      <Icon name={icon} class='size-4' />
      {eyebrow}
    </span>
    <h1>{title}</h1>
    <p>{description}</p>
  </div>

  <dl class='index-hero__stats' aria-label={statsLabel}>
    {
      stats.map(({ label, value }) => (
        <div>
          <dt>{label}</dt>
          <dd>{value}</dd>
        </div>
      ))
    }
  </dl>
</header>

<style>
  .index-hero {
    position: relative;
    display: grid;
    gap: 2rem;
    overflow: hidden;
    padding: clamp(1.5rem, 4vw, 2.75rem);
    border: 1px solid hsl(var(--border));
    border-radius: 1.75rem;
    background:
      radial-gradient(circle at 88% 0%, hsl(var(--primary) / 0.18), transparent 34%),
      linear-gradient(135deg, hsl(var(--background)), hsl(var(--muted) / 0.55));
  }

  .index-hero::after {
    position: absolute;
    right: -1.5rem;
    bottom: -4.5rem;
    color: hsl(var(--primary) / 0.065);
    font-size: 12rem;
    font-weight: 700;
    line-height: 1;
    content: var(--hero-symbol);
    pointer-events: none;
  }

  .index-hero__copy,
  .index-hero__stats {
    position: relative;
    z-index: 1;
  }

  .index-hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: hsl(var(--primary));
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0.6rem 0 0.5rem;
    font-size: clamp(2.4rem, 7vw, 4.5rem);
    font-weight: 650;
    letter-spacing: -0.055em;
    line-height: 1;
  }

  .index-hero__copy p {
    max-width: 34rem;
    margin: 0;
    color: hsl(var(--muted-foreground));
    font-size: 0.9rem;
  }

  .index-hero__stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    align-self: end;
    gap: 0.55rem;
    margin: 0;
  }

  .index-hero__stats div {
    padding: 1rem;
    border: 1px solid hsl(var(--border) / 0.78);
    border-radius: 1rem;
    background:
      linear-gradient(145deg, hsl(var(--muted) / 0.74), hsl(var(--primary) / 0.08)),
      hsl(var(--background) / 0.45);
    box-shadow:
      inset 0 1px 0 hsl(var(--background) / 0.55),
      0 12px 28px -24px hsl(var(--foreground) / 0.38);
    backdrop-filter: blur(10px);
  }

  .index-hero__stats div:nth-child(2) {
    background:
      linear-gradient(145deg, hsl(var(--primary) / 0.12), hsl(var(--muted) / 0.62)),
      hsl(var(--background) / 0.42);
  }

  .index-hero__stats div:nth-child(3) {
    background:
      linear-gradient(145deg, hsl(var(--muted) / 0.62), hsl(var(--accent) / 0.72)),
      hsl(var(--background) / 0.42);
  }

  .index-hero__stats dt {
    color: hsl(var(--muted-foreground));
    font-size: 0.66rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .index-hero__stats dd {
    margin: 0.2rem 0 0;
    font-size: 1.5rem;
    font-weight: 650;
    line-height: 1;
  }

  @media (min-width: 768px) {
    .index-hero {
      grid-template-columns: minmax(0, 1fr) minmax(22rem, 0.7fr);
    }
  }

  @media (max-width: 640px) {
    .index-hero__stats {
      grid-template-columns: 1fr;
    }
  }
</style>
