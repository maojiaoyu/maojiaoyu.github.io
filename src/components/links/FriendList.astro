---
import { Image } from 'astro:assets'

import config from '@/site-config'

interface AvatarCache {
  hash: string
  path: string
}

interface Friend {
  avatar: string
  avatar_cache?: AvatarCache
  name: string
  intro: string
  link: string
}

interface FriendList {
  id_name: string
  desc: string
  link_list: Friend[]
}

function shuffle(arr: Friend[]) {
  return arr.sort(() => {
    return Math.random() - 0.5
  })
}

const {
  title,
  list: friendList,
  ...props
} = Astro.props as {
  title?: string
  list: FriendList
}

const getAvatarSrc = (friend: Friend) =>
  (config.integ?.links?.cacheAvatar ?? false)
    ? (friend.avatar_cache?.path ?? friend.avatar)
    : friend.avatar
---

{title && <h2 id={friendList.id_name}>{title}</h2>}
<div class='grid gap-4 sm:grid-cols-2 lg:grid-cols-3' {...props}>
  {
    friendList.link_list.length > 0 ? (
      shuffle(friendList.link_list).map((frd: Friend, index) => {
        const avatarSrc = getAvatarSrc(frd)
        const isRemote = typeof avatarSrc === 'string' && avatarSrc.startsWith('http')
        return (
          <a href={frd.link} target='_blank' class='no-underline'>
            <div
              class='friend-card group relative h-full overflow-hidden rounded-2xl border bg-background p-3.5 transition-all duration-300 sm:p-4'
              style={`--friend-index:${index}`}
            >
              <div class='relative z-10 flex h-full items-center gap-3.5'>
                {/* avatar */}
                <div class='relative h-12 w-12 min-w-12 overflow-hidden rounded-full ring-1 ring-border'>
                  {isRemote ? (
                    <img
                      class='friend-avatar my-0 bg-card transition-transform duration-600'
                      src={avatarSrc}
                      height={80}
                      width={80}
                      alt='avatar'
                      loading='lazy'
                      style='object-fit: cover;'
                    />
                  ) : (
                    <Image
                      class='friend-avatar my-0 bg-card transition-transform duration-600'
                      src={avatarSrc as any}
                      height={80}
                      width={80}
                      alt='avatar'
                      loading='lazy'
                      style='object-fit: cover;'
                    />
                  )}
                  <div class='absolute start-0 top-0 h-full w-full'>
                    <div class='flex h-full w-full items-center justify-center rounded-full bg-foreground opacity-0 transition-opacity duration-300 ease-in-out group-hover:opacity-50'>
                      <svg
                        xmlns='http://www.w3.org/2000/svg'
                        width='32'
                        height='32'
                        viewBox='0 0 24 24'
                        fill='none'
                        stroke-width='2.5'
                        stroke-linecap='round'
                        stroke-linejoin='round'
                        class='me-2 stroke-background'
                      >
                        <line
                          x1='5'
                          y1='12'
                          x2='19'
                          y2='12'
                          class='translate-x-4 scale-x-0 transition-all duration-300 ease-in-out group-hover:translate-x-1 group-hover:scale-x-100'
                        />
                        <polyline
                          points='12 5 19 12 12 19'
                          class='translate-x-0 transition-all duration-300 ease-in-out group-hover:translate-x-1'
                        />
                      </svg>
                    </div>
                  </div>
                </div>
                {/* details */}
                <div class='min-w-0 flex flex-col gap-y-1'>
                  <p class='my-0 line-clamp-1 text-sm font-semibold'>{frd.name} </p>
                  <p class='my-0 line-clamp-2 text-xs leading-5 text-muted-foreground'>
                    {frd.intro}
                  </p>
                </div>
              </div>
              {/* avatar bg */}
              {isRemote ? (
                <img
                  class='absolute -start-2 top-0 z-0 my-0 h-full w-2/3 bg-white object-cover opacity-15'
                  src={avatarSrc}
                  height={80}
                  width={80}
                  alt='avatar bg'
                  loading='lazy'
                  style={{
                    objectFit: 'cover',
                    msMaskImage:
                      '-ms-linear-gradient(right, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 1) 100%)',
                    WebkitMaskImage:
                      '-webkit-linear-gradient(right, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 1) 100%)',
                    maskImage:
                      'linear-gradient(to left, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 1) 100%)'
                  }}
                />
              ) : (
                <Image
                  class='absolute -start-2 top-0 z-0 my-0 h-full w-2/3 bg-white object-cover opacity-15'
                  src={avatarSrc as any}
                  height={80}
                  width={80}
                  alt='avatar bg'
                  loading='lazy'
                  style={{
                    msMaskImage:
                      '-ms-linear-gradient(right, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 1) 100%)',
                    WebkitMaskImage:
                      '-webkit-linear-gradient(right, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 1) 100%)',
                    maskImage:
                      'linear-gradient(to left, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 1) 100%)'
                  }}
                />
              )}
            </div>
          </a>
        )
      })
    ) : (
      <p>Nothing here.</p>
    )
  }
</div>

<style>
  .friend-card {
    min-height: 5.25rem;
    isolation: isolate;
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 0.6s ease-out,
      transform 0.6s ease-out,
      border-color 180ms ease,
      background-color 180ms ease,
      box-shadow 180ms ease;
  }

  .friend-card.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .friend-card::after {
    position: absolute;
    right: -1.4rem;
    bottom: -1.4rem;
    z-index: -1;
    width: 4rem;
    height: 4rem;
    border: 1px solid hsl(var(--primary) / 0.11);
    border-radius: 50%;
    box-shadow: 0 0 0 0.6rem hsl(var(--primary) / 0.025);
    content: '';
    transition: transform 300ms ease;
  }

  .friend-card:hover {
    border-color: hsl(var(--primary) / 0.35);
    background: hsl(var(--muted) / 0.45);
    transform: translateY(-2px);
    box-shadow: 0 12px 30px hsl(var(--foreground) / 0.055);
  }

  .friend-card:hover::after {
    transform: scale(1.25);
  }
</style>

<script>
  let friendLinksController: AbortController | undefined
  let friendLinksObserver: IntersectionObserver | undefined

  function initFriendLinks() {
    friendLinksController?.abort()
    friendLinksObserver?.disconnect()
    friendLinksController = new AbortController()
    const { signal } = friendLinksController

    friendLinksObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement
            const index = parseInt(el.style.getPropertyValue('--friend-index') || '0')
            el.style.transitionDelay = `${(index % 6) * 0.06}s`
            el.classList.add('is-visible')
            friendLinksObserver?.unobserve(el)
          }
        })
      },
      { threshold: 0.01 }
    )

    const observeCards = (root: ParentNode = document) => {
      const cards = [...root.querySelectorAll<HTMLElement>('.friend-card, .timeline-event')]
      cards.forEach((el) => {
        el.classList.remove('is-visible')
        el.style.transitionDelay = '0s'
      })
      requestAnimationFrame(() => {
        requestAnimationFrame(() => cards.forEach((el) => friendLinksObserver?.observe(el)))
      })
    }

    observeCards()

    document.querySelectorAll<HTMLElement>('.friend-card').forEach((htmlCard) => {
      htmlCard.addEventListener(
        'mousemove',
        (event) => {
          const rect = htmlCard.getBoundingClientRect()
          htmlCard.style.setProperty('--mouse-x', `${event.clientX - rect.left}px`)
          htmlCard.style.setProperty('--mouse-y', `${event.clientY - rect.top}px`)
        },
        { signal }
      )
    })

    document.querySelectorAll<HTMLElement>('.friend-avatar').forEach((htmlAvatar) => {
      const link = htmlAvatar.closest('a')
      if (link) {
        link.addEventListener('mouseenter', () => (htmlAvatar.style.transform = 'rotate(360deg)'), {
          signal
        })
        link.addEventListener('mouseleave', () => (htmlAvatar.style.transform = 'rotate(0deg)'), {
          signal
        })
      }
    })

    document.addEventListener(
      'friend-panel-shown',
      (event) => {
        if (event instanceof CustomEvent && event.detail instanceof HTMLElement) {
          observeCards(event.detail)
        }
      },
      { signal }
    )

    document.addEventListener(
      'astro:before-swap',
      () => {
        friendLinksObserver?.disconnect()
        friendLinksController?.abort()
      },
      { once: true, signal }
    )
  }

  initFriendLinks()
  document.addEventListener('astro:page-load', initFriendLinks)
</script>
