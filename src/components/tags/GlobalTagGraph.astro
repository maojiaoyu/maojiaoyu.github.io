---
interface TagNode {
  name: string
  count: number
}

interface TagLink {
  source: string
  target: string
  count: number
}

interface Props {
  nodes: TagNode[]
  links: TagLink[]
}

const { nodes, links } = Astro.props
const graphData = JSON.stringify({ nodes, links }).replace(/</g, '\\u003c')
---

{
  nodes.length > 0 && (
    <section
      class='global-tag-graph animate'
      aria-labelledby='global-tag-graph-title'
      data-global-tag-graph
    >
      <div class='global-tag-graph__header'>
        <div>
          <span class='global-tag-graph__eyebrow'>Knowledge map</span>
          <h2 id='global-tag-graph-title'>Tag relationships</h2>
          <p>Tags are connected when they appear in the same post.</p>
        </div>

        <div class='global-tag-graph__actions'>
          <div class='global-tag-graph__stats' aria-label='Graph statistics'>
            <span>
              <strong>{nodes.length}</strong> nodes
            </span>
            <span>
              <strong>{links.length}</strong> links
            </span>
          </div>
          <a
            class='global-tag-graph__explore'
            href='#knowledge-graph?scope=tags&types=tag&relations=co-tag'
            data-graph-open
            data-astro-prefetch='false'
          >
            图谱中心
          </a>
          <button
            class='global-tag-graph__toggle'
            type='button'
            aria-expanded='false'
            aria-controls='global-tag-graph-content'
            data-global-tag-graph-toggle
          >
            <span data-global-tag-graph-toggle-label>View graph</span>
            <svg viewBox='0 0 24 24' aria-hidden='true'>
              <path d='m9 18 6-6-6-6' />
            </svg>
          </button>
        </div>
      </div>

      <div id='global-tag-graph-content' data-global-tag-graph-content hidden>
        <div class='global-tag-graph__legend' aria-hidden='true'>
          <span>
            <i class='is-node' />
            Larger node = more posts
          </span>
          <span>
            <i class='is-link' />
            Thicker line = stronger relationship
          </span>
        </div>

        <div class='global-tag-graph__canvas' data-global-tag-graph-canvas>
          <p data-global-tag-graph-status>Preparing tag map...</p>
        </div>

        <div class='global-tag-graph__footer'>
          <span>Drag to rearrange · Scroll to zoom · Select a tag to open</span>
          <button type='button' data-global-tag-graph-reset>
            Reset view
          </button>
        </div>
      </div>

      <script is:inline type='application/json' data-global-tag-graph-data set:html={graphData} />
    </section>
  )
}

<script>
  import('./global-tag-graph').then(({ setupGlobalTagGraph }) => setupGlobalTagGraph())
</script>

<style>
  .global-tag-graph {
    margin-top: 2.75rem;
    padding: clamp(1.1rem, 3vw, 1.5rem);
    border: 1px solid hsl(var(--border));
    border-radius: 1.35rem;
    background: hsl(var(--background));
  }

  .global-tag-graph__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .global-tag-graph__eyebrow {
    color: hsl(var(--primary));
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .global-tag-graph h2 {
    margin: 0.15rem 0 0;
    font-size: 1.3rem;
    font-weight: 600;
  }

  .global-tag-graph__header p {
    margin: 0.3rem 0 0;
    color: hsl(var(--muted-foreground));
    font-size: 0.78rem;
  }

  .global-tag-graph__stats {
    display: flex;
    flex: 0 0 auto;
    gap: 0.5rem;
  }

  .global-tag-graph__actions {
    display: flex;
    flex: 0 0 auto;
    align-items: center;
    gap: 0.65rem;
  }

  .global-tag-graph__stats span {
    padding: 0.45rem 0.65rem;
    border: 1px solid hsl(var(--border));
    border-radius: 0.7rem;
    background: hsl(var(--muted) / 0.4);
    color: hsl(var(--muted-foreground));
    font-size: 0.7rem;
  }

  .global-tag-graph__stats strong {
    color: hsl(var(--foreground));
  }

  .global-tag-graph__toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.55rem 0.75rem;
    border: 1px solid hsl(var(--border));
    border-radius: 0.8rem;
    background: hsl(var(--muted) / 0.55);
    color: hsl(var(--foreground));
    cursor: pointer;
    font-size: 0.75rem;
    transition:
      border-color 180ms ease,
      color 180ms ease,
      background 180ms ease;
  }

  .global-tag-graph__explore {
    color: hsl(var(--primary));
    font-size: 0.7rem;
    white-space: nowrap;
  }

  .global-tag-graph__toggle:hover {
    border-color: hsl(var(--primary) / 0.55);
    background: hsl(var(--primary) / 0.08);
    color: hsl(var(--primary));
  }

  .global-tag-graph__toggle svg {
    width: 1rem;
    height: 1rem;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2;
    transition: transform 180ms ease;
  }

  .global-tag-graph__toggle[aria-expanded='true'] svg {
    transform: rotate(90deg);
  }

  .global-tag-graph__legend {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem 1.1rem;
    margin: 1rem 0 0.65rem;
    color: hsl(var(--muted-foreground));
    font-size: 0.68rem;
  }

  .global-tag-graph__legend span {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .global-tag-graph__legend i {
    display: inline-block;
  }

  .global-tag-graph__legend .is-node {
    width: 0.65rem;
    height: 0.65rem;
    border: 2px solid hsl(var(--primary) / 0.8);
    border-radius: 999px;
    background: hsl(var(--primary) / 0.15);
  }

  .global-tag-graph__legend .is-link {
    width: 1rem;
    height: 2px;
    background: hsl(var(--primary) / 0.55);
  }

  .global-tag-graph__canvas {
    position: relative;
    height: clamp(28rem, 62vw, 43rem);
    overflow: hidden;
    border: 1px solid hsl(var(--border));
    border-radius: 1rem;
    background:
      radial-gradient(circle at 50% 45%, hsl(var(--primary) / 0.08), transparent 42%),
      linear-gradient(hsl(var(--muted) / 0.22), hsl(var(--background)));
  }

  .global-tag-graph__canvas > p {
    position: absolute;
    inset: 0;
    display: grid;
    margin: 0;
    place-items: center;
    color: hsl(var(--muted-foreground));
    font-size: 0.8rem;
  }

  .global-tag-graph__canvas :global(svg) {
    display: block;
    width: 100%;
    height: 100%;
  }

  .global-tag-graph__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 0.6rem;
    color: hsl(var(--muted-foreground));
    font-size: 0.68rem;
  }

  .global-tag-graph__footer button {
    border: 0;
    background: none;
    color: hsl(var(--primary));
    cursor: pointer;
    font: inherit;
  }

  .global-tag-graph__footer button:hover {
    text-decoration: underline;
  }

  [hidden] {
    display: none !important;
  }

  @media (max-width: 639px) {
    .global-tag-graph__header {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.8rem;
    }

    .global-tag-graph__canvas {
      height: 31rem;
    }

    .global-tag-graph__actions {
      width: 100%;
      align-items: stretch;
      justify-content: space-between;
    }

    .global-tag-graph__footer {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.35rem;
    }
  }
</style>
