---
import type { CollectionEntry } from 'astro:content'

import { Icon } from 'astro-pure/user'
import { getCategoryLabel, getPostCategorySegments } from '@/utils/content-paths'

interface Props {
  post: CollectionEntry<'blog'>
  inboundLinks: number
  outboundLinks: number
  readingTime?: string
}

const { post, inboundLinks, outboundLinks, readingTime } = Astro.props
const categories = getPostCategorySegments(post)
const published = post.data.publishDate
const updated = post.data.updatedDate
const relatedLinks = inboundLinks + outboundLinks
const relatedTarget = relatedLinks > 0 ? '#wikilinks-section' : '#blog-graph-view'

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('zh-CN', {
    year: 'numeric',
    month: 'short',
    day: 'numeric'
  }).format(date)
---

<nav class='article-rail' aria-label='文章辅助导航'>
  <div class='rail-header'>
    <div class='progress-circle-container'>
      <svg class='progress-circle' viewBox='0 0 36 36'>
        <path
          class='circle-bg'
          d='M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831'></path>
        <path
          id='rail-progress-path'
          class='circle-fill'
          stroke-dasharray='0, 100'
          d='M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831'></path>
      </svg>
      <div id='rail-progress-text' class='progress-text'>0%</div>
    </div>
    <div class='header-info'>
      <h2>阅读概览</h2>
    </div>
  </div>

  <div class='action-pill-group'>
    <a href='/blog' class='action-pill' title='返回博客首页'>
      <Icon name='document' />
      <span>首页</span>
    </a>
    <a href={relatedTarget} class='action-pill' title='查看文章关联' data-related-jump>
      <Icon name='link' />
      <span>关联</span>
    </a>
    <a href='#' onclick='history.back(); return false;' class='action-pill' title='返回上一页'>
      <svg viewBox='0 0 24 24' aria-hidden='true'>
        <path d='m15 18-6-6 6-6'></path>
      </svg>
      <span>返回</span>
    </a>
  </div>

  <div class='rail-details'>
    <div class='rail-metrics'>
      <div>
        <span>预计阅读</span>
        <strong>{!readingTime || readingTime === '0 min' ? '1 min' : readingTime}</strong>
      </div>
      {
        relatedLinks > 0 && (
          <div>
            <span>关联链接</span>
            <strong>{relatedLinks} 条</strong>
          </div>
        )
      }
    </div>

    {
      categories.length > 0 && (
        <div class='rail-categories'>
          <span class='rail-details__label'>文章分类</span>
          <div class='category-links'>
            {categories.map((category) => (
              <a href={`/categories/${category.path}`}>{getCategoryLabel(category.name)}</a>
            ))}
          </div>
        </div>
      )
    }

    <div class='rail-dates'>
      <div>
        <span>发布</span>
        <time datetime={published.toISOString()}>{formatDate(published)}</time>
      </div>
      {
        updated && (
          <div>
            <span>更新</span>
            <time datetime={updated.toISOString()}>{formatDate(updated)}</time>
          </div>
        )
      }
    </div>
  </div>
</nav>

<script>
  function setupReadingAnalytics() {
    const progressPath = document.getElementById('rail-progress-path') as SVGPathElement | null
    const progressText = document.getElementById('rail-progress-text')
    const contentEl = document.getElementById('content')
    if (!progressPath || !progressText || !contentEl || progressPath.dataset.ready === 'true')
      return

    progressPath.dataset.ready = 'true'
    let ticking = false

    const updateReadingAnalytics = () => {
      const scrollTop = Math.max(0, window.scrollY || document.documentElement.scrollTop)
      const maxScrollable = Math.max(
        0,
        contentEl.offsetTop + contentEl.scrollHeight - window.innerHeight
      )
      const progress =
        maxScrollable === 0 ? 0 : Math.max(0, Math.min(100, (scrollTop / maxScrollable) * 100))

      progressPath.setAttribute('stroke-dasharray', `${progress}, 100`)
      progressText.textContent = `${Math.round(progress)}%`
      ticking = false
    }

    const requestUpdate = () => {
      if (ticking) return
      ticking = true
      requestAnimationFrame(updateReadingAnalytics)
    }

    window.addEventListener('scroll', requestUpdate, { passive: true })
    window.addEventListener('resize', requestUpdate)
    updateReadingAnalytics()
  }

  setupReadingAnalytics()
  document.addEventListener('astro:page-load', setupReadingAnalytics)
</script>

<style>
  .article-rail {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .rail-header {
    display: flex;
    align-items: center;
    gap: 0.72rem;
  }

  .progress-circle-container {
    position: relative;
    width: 2.35rem;
    height: 2.35rem;
    flex-shrink: 0;
  }

  .progress-circle {
    width: 100%;
    height: 100%;
    transform: rotate(-90deg);
  }

  .circle-bg {
    fill: none;
    stroke: hsl(var(--border));
    stroke-width: 2.5;
  }

  .circle-fill {
    fill: none;
    stroke: hsl(var(--primary));
    stroke-width: 2.5;
    stroke-linecap: round;
    transition: stroke-dasharray 120ms ease-out;
  }

  .progress-text {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    color: hsl(var(--foreground));
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 600;
  }

  .header-info h2 {
    margin: 0;
    color: hsl(var(--foreground));
    font-size: 1rem;
    font-weight: 500;
  }

  .action-pill-group {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.3rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid hsl(var(--border) / 0.68);
  }

  .action-pill {
    display: flex;
    min-width: 0;
    align-items: center;
    justify-content: center;
    gap: 0.28rem;
    padding: 0.42rem 0.18rem;
    border: 0;
    border-radius: 0.45rem;
    color: hsl(var(--muted-foreground));
    background: transparent;
    font-size: 0.78rem;
    text-decoration: none;
    white-space: nowrap;
    transition:
      border-color 160ms ease,
      color 160ms ease,
      background-color 160ms ease;
  }

  .action-pill:hover {
    color: hsl(var(--primary));
    background: hsl(var(--primary) / 0.07);
  }

  .action-pill :global(svg) {
    width: 0.9rem;
    height: 0.9rem;
    flex-shrink: 0;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2;
  }

  .rail-details {
    display: grid;
    gap: 0;
  }

  .rail-metrics {
    display: flex;
    flex-direction: column;
  }

  .rail-metrics div {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.65rem;
    min-height: 2.15rem;
    padding: 0.48rem 0.15rem;
    border-bottom: 1px solid hsl(var(--border) / 0.55);
  }

  .rail-metrics div + div {
    border-top: 1px solid hsl(var(--border) / 0.55);
  }

  .rail-metrics strong {
    overflow: hidden;
    color: hsl(var(--foreground) / 0.84);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 500;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .rail-metrics span,
  .rail-details__label,
  .rail-dates span {
    color: hsl(var(--muted-foreground));
    font-size: 0.72rem;
  }

  .rail-categories {
    display: grid;
    gap: 0.45rem;
    padding: 0.72rem 0.15rem;
    border-bottom: 1px solid hsl(var(--border) / 0.55);
  }

  .category-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.32rem;
  }

  .category-links a {
    overflow: hidden;
    max-width: 100%;
    padding: 0;
    border-radius: 0;
    color: hsl(var(--foreground) / 0.76);
    background: transparent;
    font-size: 0.78rem;
    text-decoration: underline;
    text-decoration-color: hsl(var(--border));
    text-decoration-style: dotted;
    text-underline-offset: 0.2rem;
    text-overflow: ellipsis;
    white-space: nowrap;
    transition:
      color 160ms ease,
      background-color 160ms ease;
  }

  .category-links a:hover {
    color: hsl(var(--primary));
    background: transparent;
  }

  .rail-dates {
    display: grid;
    gap: 0;
    padding-top: 0.25rem;
  }

  .rail-dates div {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.65rem;
    min-height: 2rem;
    padding: 0.42rem 0.15rem;
  }

  .rail-dates time {
    overflow: hidden;
    color: hsl(var(--foreground) / 0.68);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
</style>
