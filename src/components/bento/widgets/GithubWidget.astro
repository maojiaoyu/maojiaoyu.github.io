---
import BentoCard from '../BentoCard.astro'
import { Icon } from 'astro-pure/user'
---

<BentoCard class="col-span-1 md:col-span-2 row-span-1 flex flex-col justify-between" color="#10b981">
  <div class="flex items-center justify-between mb-4">
    <div class="flex items-center gap-2 text-muted-foreground">
      <Icon name="github" class="size-5" />
      <span class="text-sm font-medium">GitHub Activity</span>
    </div>
    <a href="https://github.com/maojiaoyu" target="_blank" class="text-xs text-primary hover:underline">@maojiaoyu</a>
  </div>
  
  <div class="flex-1 w-full flex items-center justify-center overflow-hidden rounded-xl bg-background/50 border border-border/30 p-2">
    {/* Using the same github chart from projects page, but styled for the bento box */}
    <img
      src="https://ghchart.rshah.org/B19CD9/maojiaoyu"
      alt="github activities"
      class="w-full h-full object-cover opacity-80 hover:opacity-100 transition-opacity"
      loading="lazy"
      decoding="async"
      style="filter: hue-rotate(var(--hue-rotation, 0deg));"
    />
  </div>
</BentoCard>

<style>
  /* Optional: Adjust hue in dark mode if needed, though B19CD9 is already specified in the URL */
  :global(.dark) img {
    filter: brightness(0.9) contrast(1.2);
  }
</style>
