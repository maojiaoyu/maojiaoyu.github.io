---
import type { ImageMetadata } from 'astro'
import { Image } from 'astro:assets'
import BentoCard from '../BentoCard.astro'

const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/projects/*.{jpeg,jpg,png,gif,avif,webp}')
const imagePath = '/src/assets/projects/1.avif'
if (!images[imagePath]) throw new Error(`"${imagePath}" does not exist in glob`)
---

<BentoCard class="col-span-1 row-span-2 p-0 hover-invert" href="https://github.com/maojiaoyu/maojiaoyu.github.io" color="#00d2d3">
  <div class="absolute inset-0 z-0">
    <Image 
      src={images[imagePath]()} 
      alt="Astro Theme maojiaoyu" 
      class="w-full h-full object-cover opacity-40 transition-transform duration-700 group-hover:scale-110 group-hover:opacity-20"
      width={400}
      height={600}
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-background/90 via-background/50 to-transparent"></div>
  </div>
  
  <div class="relative z-10 h-full w-full p-6 flex flex-col justify-end">
    <div class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg bg-background/50 backdrop-blur-md text-xs font-medium w-fit mb-3 border border-border/50 shadow-sm">
      <span class="size-1.5 rounded-full bg-green-400"></span>
      Featured
    </div>
    <h3 class="text-xl font-bold tracking-tight mb-1 text-foreground">Astro Theme maojiaoyu</h3>
    <p class="text-sm text-muted-foreground line-clamp-2">A clean, fast, and highly customizable personal blog theme built with Astro.</p>
  </div>
</BentoCard>
