---
interface Props {
  title: string
  eyebrow?: string
  description?: string
}

const { title, eyebrow, description } = Astro.props
---

<header class='content-page-hero'>
  {eyebrow && <span class='content-page-hero__eyebrow'>{eyebrow}</span>}
  <h1>{title}</h1>
  {description && <p>{description}</p>}
  <div class='content-page-hero__meta'><slot /></div>
</header>

<style>
  .content-page-hero {
    max-width: 46rem;
    padding-block: clamp(1.5rem, 5vw, 3.5rem) clamp(1.25rem, 4vw, 2.5rem);
  }

  .content-page-hero__eyebrow {
    color: hsl(var(--muted-foreground));
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0.55rem 0 0;
    font-size: clamp(2.4rem, 7vw, 4.25rem);
    font-weight: 650;
    letter-spacing: -0.05em;
    line-height: 1;
  }

  .content-page-hero > p {
    max-width: 40rem;
    margin: 0.85rem 0 0;
    color: hsl(var(--muted-foreground));
    font-size: 0.92rem;
    line-height: 1.7;
  }

  .content-page-hero__meta {
    margin-top: 0.8rem;
    color: hsl(var(--muted-foreground));
    font-size: 0.8rem;
  }

  .content-page-hero__meta:empty {
    display: none;
  }
</style>
