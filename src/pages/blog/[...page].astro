---
import type { GetStaticPaths, Page } from 'astro'
import { Image } from 'astro:assets'
import { render, type CollectionEntry } from 'astro:content'

import { getBlogCollection, getUniqueTagsWithCount, sortMDByDate } from 'astro-pure/server'
import { Icon } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'
import KnowledgeIndexHero from '@/components/KnowledgeIndexHero.astro'
import {
  getAllCategories,
  getCategoryLabel,
  getPostCategory,
  getPostPath
} from '@/utils/content-paths'
import config from '@/site-config'

export const prerender = true

export const getStaticPaths = (async ({ paginate }) => {
  const pageSize = config.content.blogPageSize ?? 10
  const collections = sortMDByDate(await getBlogCollection()) as CollectionEntry<'blog'>[]
  const tags = getUniqueTagsWithCount(collections)
    .sort(
      ([tagA, countA], [tagB, countB]) =>
        countB - countA || tagA.localeCompare(tagB, undefined, { sensitivity: 'base' })
    )
    .slice(0, 8)
  const categories = [...getAllCategories(collections).entries()]
    .filter(([category]) => !category.includes('/'))
    .map(([path, posts]) => ({
      path,
      title: getCategoryLabel(path),
      count: posts.length
    }))
    .sort((a, b) => b.count - a.count || a.title.localeCompare(b.title))

  return paginate(collections, {
    pageSize,
    props: {
      tags,
      categories,
      collectionsCount: collections.length,
      categoryCount: getAllCategories(collections).size,
      tagCount: getUniqueTagsWithCount(collections).length
    }
  })
}) satisfies GetStaticPaths

const { page, tags, categories, collectionsCount, categoryCount, tagCount } = Astro.props as {
  page: Page<CollectionEntry<'blog'>>
  tags: Array<[string, number]>
  categories: Array<{ path: string; title: string; count: number }>
  collectionsCount: number
  categoryCount: number
  tagCount: number
}
const pageSize = config.content.blogPageSize ?? 10
const posts = await Promise.all(
  page.data.map(async (post) => {
    const { remarkPluginFrontmatter } = await render(post)
    return {
      post,
      readingTime: remarkPluginFrontmatter.minutesRead as string,
      category: getPostCategory(post)
    }
  })
)

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('zh-CN', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit'
  }).format(date)

const meta = {
  description: '浏览博客文章、专题分类与持续整理的知识记录',
  title: '博客'
}
---

<PageLayout {meta}>
  <main class='blog-index mt-6 lg:mt-10'>
    <KnowledgeIndexHero
      icon='document'
      eyebrow='Writing archive'
      title='博客'
      description='记录技术实践、阶段思考与持续整理中的知识线索。'
      stats={[
        { label: '文章', value: collectionsCount },
        { label: '分类', value: categoryCount },
        { label: '标签', value: tagCount }
      ]}
      statsLabel='博客统计'
      symbol='✦'
    />

    <nav class='blog-portals animate' aria-label='博客浏览入口'>
      <a href='/categories'>
        <span class='portal-icon'><Icon name='package' /></span>
        <span>
          <strong>按分类浏览</strong>
          <small>{categoryCount} 个知识目录</small>
        </span>
        <span class='portal-arrow'>↗</span>
      </a>
      <a href='/tags'>
        <span class='portal-icon'><Icon name='hashtag' /></span>
        <span>
          <strong>沿标签发现</strong>
          <small>{tagCount} 个主题线索</small>
        </span>
        <span class='portal-arrow'>↗</span>
      </a>
      <a href='/archives'>
        <span class='portal-icon'><Icon name='time' /></span>
        <span>
          <strong>进入时光机</strong>
          <small>按发布时间回看</small>
        </span>
        <span class='portal-arrow'>↗</span>
      </a>
    </nav>

    {
      page.data.length === 0 ? (
        <section id='content' class='blog-empty animate'>
          <span>✦</span>
          <h2>还没有文章</h2>
          <p>发布后的内容会出现在这里。</p>
        </section>
      ) : (
        <>
          <section id='content' class='post-stream animate' aria-labelledby='post-stream-title'>
            <header class='stream-header'>
              <div>
                <span>Latest writing</span>
                <h2 id='post-stream-title'>最近文章</h2>
              </div>
              <p>
                第 {page.currentPage} / {page.lastPage} 页 · 本页 {page.data.length} 篇
              </p>
            </header>

            <ol class='post-list'>
              {posts.map(({ post, readingTime, category }, index) => {
                const postDate = post.data.updatedDate ?? post.data.publishDate
                const categoryLabel = category
                  ? getCategoryLabel(category.split('/').at(-1) ?? category)
                  : '未分类'
                const sequence = String((page.currentPage - 1) * pageSize + index + 1).padStart(
                  2,
                  '0'
                )

                return (
                  <li>
                    <article
                      class:list={['post-card', post.data.heroImage && 'has-cover']}
                      style={
                        post.data.heroImage?.color
                          ? `--post-accent:${post.data.heroImage.color}`
                          : undefined
                      }
                    >
                      <a class='post-card__main' href={getPostPath(post)} data-astro-prefetch>
                        <div class='post-card__content'>
                          <div class='post-card__meta'>
                            <span>{sequence}</span>
                            <time datetime={postDate.toISOString()}>{formatDate(postDate)}</time>
                            <span aria-hidden='true'>·</span>
                            <span>{categoryLabel}</span>
                          </div>

                          <h3>
                            {post.data.draft && <span>草稿</span>}
                            {post.data.title}
                          </h3>
                          <p>{post.data.description}</p>

                          <div class='post-card__footer'>
                            <span>
                              <Icon name='time' /> {readingTime}
                            </span>
                            {post.data.language && (
                              <span>
                                <Icon name='earth' /> {post.data.language}
                              </span>
                            )}
                          </div>
                        </div>

                        {post.data.heroImage && (
                          <div class='post-card__cover'>
                            <Image
                              alt={post.data.heroImage.alt || post.data.title}
                              loading={index === 0 ? 'eager' : 'lazy'}
                              {...post.data.heroImage}
                            />
                          </div>
                        )}
                      </a>

                      <div class='post-card__bottom'>
                        {post.data.tags.length > 0 && (
                          <ul class='post-card__tags' aria-label='文章标签'>
                            {post.data.tags.slice(0, 3).map((tag) => (
                              <li>
                                <a href={`/tags/${encodeURIComponent(tag)}`}>#{tag}</a>
                              </li>
                            ))}
                          </ul>
                        )}
                        <a class='post-card__read' href={getPostPath(post)} data-astro-prefetch>
                          阅读全文 <b>→</b>
                        </a>
                      </div>
                    </article>
                  </li>
                )
              })}
            </ol>

            {(page.url.prev || page.url.next) && (
              <nav class='blog-pagination' aria-label='博客分页'>
                {page.url.prev ? (
                  <a href={page.url.prev} data-astro-prefetch>
                    <span>←</span>
                    <small>上一页</small>
                  </a>
                ) : (
                  <span />
                )}
                <strong>
                  {page.currentPage} / {page.lastPage}
                </strong>
                {page.url.next ? (
                  <a href={page.url.next} data-astro-prefetch>
                    <small>下一页</small>
                    <span>→</span>
                  </a>
                ) : (
                  <span />
                )}
              </nav>
            )}
          </section>

          <section class='blog-discovery animate' aria-label='热门分类与标签'>
            <div>
              <header>
                <span>Folders</span>
                <h2>常用分类</h2>
              </header>
              <ul>
                {categories.slice(0, 5).map((category) => (
                  <li>
                    <a href={`/categories/${category.path}`}>
                      <span>{category.title}</span>
                      <small>{category.count}</small>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
            <div>
              <header>
                <span>Topics</span>
                <h2>活跃标签</h2>
              </header>
              <ul class='tag-cloud'>
                {tags.map(([tag, count]) => (
                  <li>
                    <a href={`/tags/${encodeURIComponent(tag)}`}>
                      <span>#{tag}</span>
                      <small>{count}</small>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </section>
        </>
      )
    }
  </main>

  <style>
    .blog-index {
      width: min(100%, 68rem);
      margin-inline: auto;
    }

    .blog-portals {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.75rem;
      margin-top: 1rem;
    }

    .blog-portals a {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      align-items: center;
      gap: 0.75rem;
      padding: 0.9rem 1rem;
      border: 1px solid hsl(var(--border));
      border-radius: 1rem;
      background: hsl(var(--background) / 0.72);
      text-decoration: none;
      transition:
        border-color 180ms ease,
        transform 180ms ease,
        background 180ms ease;
    }

    .blog-portals a:hover {
      transform: translateY(-2px);
      border-color: hsl(var(--primary) / 0.45);
      background: hsl(var(--muted) / 0.46);
    }

    .portal-icon {
      display: grid;
      width: 2.3rem;
      height: 2.3rem;
      place-items: center;
      border-radius: 0.75rem;
      color: hsl(var(--primary));
      background: hsl(var(--primary) / 0.1);
    }

    .portal-icon :global(svg) {
      width: 1.1rem;
      height: 1.1rem;
    }

    .blog-portals strong,
    .blog-portals small {
      display: block;
    }

    .blog-portals strong {
      font-size: 0.84rem;
      font-weight: 600;
    }

    .blog-portals small,
    .portal-arrow {
      color: hsl(var(--muted-foreground));
      font-size: 0.68rem;
    }

    .post-stream {
      margin-top: 3rem;
    }

    .stream-header {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 1rem;
    }

    .stream-header span,
    .blog-discovery header span {
      color: hsl(var(--primary));
      font-size: 0.66rem;
      font-weight: 700;
      letter-spacing: 0.11em;
      text-transform: uppercase;
    }

    .stream-header h2,
    .blog-discovery h2 {
      margin: 0.15rem 0 0;
      font-size: 1.3rem;
      font-weight: 620;
    }

    .stream-header p {
      margin: 0;
      color: hsl(var(--muted-foreground));
      font-size: 0.72rem;
    }

    .post-list {
      display: grid;
      gap: 0.8rem;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .post-card {
      --post-accent: hsl(var(--primary));
      position: relative;
      overflow: hidden;
      border: 1px solid hsl(var(--border));
      border-radius: 1.25rem;
      background:
        linear-gradient(135deg, hsl(var(--background)), hsl(var(--muted) / 0.28)),
        hsl(var(--background));
      transition:
        border-color 200ms ease,
        box-shadow 200ms ease,
        transform 200ms ease;
    }

    .post-card:hover {
      transform: translateY(-2px);
      border-color: color-mix(in srgb, var(--post-accent) 45%, hsl(var(--border)));
      box-shadow: 0 18px 44px -34px hsl(var(--foreground) / 0.42);
    }

    .post-card__main {
      position: relative;
      display: block;
      min-height: 11.5rem;
      color: inherit;
      text-decoration: none;
      isolation: isolate;
    }

    .post-card.has-cover .post-card__main::after {
      position: absolute;
      inset: 0;
      z-index: -1;
      background: linear-gradient(
        90deg,
        hsl(var(--background)) 0%,
        hsl(var(--background) / 0.96) 34%,
        hsl(var(--background) / 0.68) 62%,
        hsl(var(--background) / 0.08) 100%
      );
      content: '';
      pointer-events: none;
    }

    .post-card__content {
      position: relative;
      z-index: 1;
      display: flex;
      min-width: 0;
      min-height: 11.5rem;
      flex-direction: column;
      padding: 1.35rem 1.5rem 1rem;
    }

    .post-card__meta {
      display: flex;
      align-items: center;
      gap: 0.45rem;
      color: hsl(var(--muted-foreground));
      font-family: var(--font-mono);
      font-size: 0.66rem;
    }

    .post-card__meta > span:first-child {
      color: hsl(var(--primary));
      font-weight: 700;
    }

    .post-card h3 {
      margin: 0.75rem 0 0.35rem;
      font-size: clamp(1.25rem, 3vw, 1.65rem);
      font-weight: 640;
      letter-spacing: -0.025em;
      line-height: 1.2;
      transition: color 180ms ease;
    }

    .post-card:hover h3 {
      color: color-mix(in srgb, var(--post-accent) 78%, hsl(var(--foreground)));
    }

    .post-card h3 > span {
      margin-right: 0.45rem;
      padding: 0.16rem 0.38rem;
      border-radius: 0.35rem;
      color: hsl(var(--destructive));
      background: hsl(var(--destructive) / 0.1);
      font-size: 0.62rem;
      vertical-align: middle;
    }

    .post-card__content > p {
      display: -webkit-box;
      overflow: hidden;
      margin: 0;
      color: hsl(var(--muted-foreground));
      font-size: 0.82rem;
      line-height: 1.65;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 2;
    }

    .post-card__footer {
      display: flex;
      align-items: center;
      gap: 0.8rem;
      margin-top: auto;
      padding-top: 1rem;
      color: hsl(var(--muted-foreground));
      font-size: 0.68rem;
    }

    .post-card__footer span {
      display: inline-flex;
      align-items: center;
      gap: 0.25rem;
    }

    .post-card__footer :global(svg) {
      width: 0.85rem;
      height: 0.85rem;
    }

    .post-card__read {
      margin-left: auto;
      color: hsl(var(--foreground));
      font-size: 0.68rem;
      text-decoration: none;
      white-space: nowrap;
    }

    .post-card__read b {
      transition: transform 180ms ease;
    }

    .post-card:hover .post-card__read b {
      transform: translateX(0.2rem);
    }

    .post-card__cover {
      position: absolute;
      inset: 0;
      z-index: -2;
      overflow: hidden;
      pointer-events: none;
    }

    .post-card__cover :global(img) {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      opacity: 0.82;
      transition:
        opacity 300ms ease,
        transform 500ms ease;
    }

    .post-card:hover .post-card__cover :global(img) {
      opacity: 1;
      transform: scale(1.025);
    }

    .post-card__bottom {
      position: relative;
      z-index: 1;
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0 1.5rem 1.15rem;
    }

    .post-card__tags {
      display: flex;
      min-width: 0;
      flex-wrap: wrap;
      gap: 0.4rem;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .post-card__tags a {
      display: block;
      padding: 0.22rem 0.5rem;
      border-radius: 999px;
      color: hsl(var(--muted-foreground));
      background: hsl(var(--muted) / 0.65);
      font-size: 0.64rem;
      text-decoration: none;
    }

    .post-card__tags a:hover {
      color: hsl(var(--primary));
      background: hsl(var(--primary) / 0.1);
    }

    .blog-pagination {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      gap: 1rem;
      margin-top: 1.25rem;
      padding: 0.75rem;
      border-top: 1px solid hsl(var(--border));
    }

    .blog-pagination a {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      width: fit-content;
      color: hsl(var(--foreground));
      text-decoration: none;
    }

    .blog-pagination a:last-child {
      justify-self: end;
    }

    .blog-pagination small {
      color: hsl(var(--muted-foreground));
    }

    .blog-pagination strong {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      font-weight: 500;
    }

    .blog-discovery {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.8rem;
      margin-top: 3rem;
    }

    .blog-discovery > div {
      padding: 1.2rem;
      border: 1px solid hsl(var(--border));
      border-radius: 1.2rem;
      background: hsl(var(--muted) / 0.2);
    }

    .blog-discovery ul {
      display: flex;
      flex-wrap: wrap;
      gap: 0.45rem;
      margin: 1rem 0 0;
      padding: 0;
      list-style: none;
    }

    .blog-discovery a {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      padding: 0.38rem 0.62rem;
      border: 1px solid hsl(var(--border));
      border-radius: 0.65rem;
      color: hsl(var(--foreground));
      background: hsl(var(--background) / 0.7);
      font-size: 0.72rem;
      text-decoration: none;
    }

    .blog-discovery a:hover {
      border-color: hsl(var(--primary) / 0.42);
      color: hsl(var(--primary));
    }

    .blog-discovery small {
      color: hsl(var(--muted-foreground));
      font-family: var(--font-mono);
      font-size: 0.62rem;
    }

    .blog-empty {
      padding: 5rem 1rem;
      text-align: center;
    }

    .blog-empty > span {
      color: hsl(var(--primary));
      font-size: 2rem;
    }

    .blog-empty h2 {
      margin: 0.8rem 0 0.25rem;
    }

    .blog-empty p {
      margin: 0;
      color: hsl(var(--muted-foreground));
    }

    @media (max-width: 767px) {
      .blog-portals,
      .blog-discovery {
        grid-template-columns: 1fr;
      }

      .post-card.has-cover .post-card__main::after {
        background: linear-gradient(
          0deg,
          hsl(var(--background)) 0%,
          hsl(var(--background) / 0.94) 45%,
          hsl(var(--background) / 0.28) 78%,
          transparent 100%
        );
      }

      .post-card__cover {
        bottom: auto;
        height: 12rem;
      }

      .post-card__content {
        padding: 1.1rem 1.15rem 0.9rem;
      }

      .post-card__bottom {
        padding-inline: 1.15rem;
      }
    }

    @media (max-width: 480px) {
      .stream-header {
        align-items: flex-start;
        flex-direction: column;
        gap: 0.25rem;
      }

      .post-card__meta {
        flex-wrap: wrap;
      }

      .post-card__footer {
        flex-wrap: wrap;
      }

      .post-card__read {
        width: 100%;
        margin-left: 0;
      }
    }
  </style>
</PageLayout>
