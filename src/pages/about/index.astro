---
import { Collapse, Timeline } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'
import HobbySection from '@/components/about/HobbySection.astro'
import Substats from '@/components/about/Substats.astro'
import ToolSection from '@/components/about/ToolSection.astro'
import blueskyIcon from '@/assets/social/bluesky.png'
import facebookIcon from '@/assets/social/facebook.png'
import farcasterIcon from '@/assets/social/farcaster.png'
// Social icons
import fireflyIcon from '@/assets/social/firefly.png'
import lensIcon from '@/assets/social/lens.png'
import paragraphIcon from '@/assets/social/paragraph.png'
import kvmIcon from '@/assets/tools/kvm.png'
import luaIcon from '@/assets/tools/lua.gif'

const headings = [
  { depth: 2, slug: 'hobbies', text: '爱好' },
  { depth: 2, slug: 'tools', text: '工具' },
  { depth: 2, slug: 'social-networks', text: '社交网络' },
  { depth: 2, slug: 'gossips', text: '闲话' },
  { depth: 2, slug: 'about-blog', text: '关于博客' }
]
---

<PageLayout title='关于' {headings} view comment hideBack hideTitle>
  {/* Left-aligned hero, consistent with navbar */}
  <div class='mt-6 mb-16 flex flex-col items-start'>
    <div
      class='inline-block rounded-full bg-primary/10 px-3 py-1 text-sm font-medium text-primary mb-4'
    >
      Here is Ling
    </div>
    <h1 class='text-4xl font-bold tracking-tight text-foreground sm:text-6xl mb-4'>
      关于我 / About Me
    </h1>
    <p class='text-xl text-muted-foreground font-medium'>既有缘相识，祝你心想事成</p>
    <p class='text-base text-muted-foreground/80 mt-1'>
      Now that you have met by fate, I wish you all the best of luck
    </p>
  </div>

  {/* Gossips Section */}
  <div
    class='group flex flex-col overflow-hidden rounded-3xl border border-border/40 bg-background/40 backdrop-blur-md shadow-sm transition-all duration-500 hover:-translate-y-1 hover:border-transparent hover:shadow-[0_10px_30px_-10px_var(--primary)] mb-10'
  >
    <div class='p-6 sm:p-8 pt-5 sm:pt-7'>
      <h2 id='gossips' class='mt-0 mb-6'>闲话</h2>
      <div class='mb-2'>
        <Collapse title='待补充'> 这里可以写一些个人的想法、感悟或者其他内容。 </Collapse>
      </div>
    </div>
  </div>

  {/* About Blog Section */}
  <div
    class='group flex flex-col overflow-hidden rounded-3xl border border-border/40 bg-background/40 backdrop-blur-md shadow-sm transition-all duration-500 hover:-translate-y-1 hover:border-transparent hover:shadow-[0_10px_30px_-10px_var(--primary)]'
  >
    <div class='p-6 sm:p-8 pt-5 sm:pt-7'>
      <h2 id='about-blog' class='mt-0 mb-4'>关于博客</h2>
      <p class='text-muted-foreground mt-0 mb-6'>网站历史：</p>
      <Timeline
        events={[
          {
            date: '2025-5-10',
            content:
              '使用 <a href="https://typecho.org/" target="_blank" class="text-primary hover:underline">Typecho</a> 主题建站'
          },
          {
            date: '2026-6-28',
            content:
              '迁移至魔改的 <a href="https://github.com/LemonAdorable/astro-theme-iris" target="_blank" class="text-primary hover:underline">Astro Theme Iris</a> 主题'
          }
        ]}
      />
      <div class='mt-8 rounded-2xl border border-dashed border-primary/20 bg-primary/5 p-5'>
        <p class='mb-3 text-sm text-foreground/80'>
          本站的平稳运行与个性化定制，离不开以下优秀项目与开源社区提供的资源和技术支持：
        </p>
        <ul class='list-disc pl-5 space-y-1 text-sm text-muted-foreground'>
          <li>
            Site hosting: <a
              href='https://pages.github.com/'
              target='_blank'
              class='text-primary hover:underline'>GitHub Pages</a
            >
          </li>
          <li>
            Framework & Theme: <a
              href='https://astro.build/'
              target='_blank'
              class='text-primary hover:underline'>Astro</a
            > + <a
              href='https://github.com/LemonAdorable/astro-theme-iris'
              target='_blank'
              class='text-primary hover:underline'>Astro Theme Iris</a
            >
          </li>
          <li>
            CI/CD: <a
              href='https://github.com/features/actions'
              target='_blank'
              class='text-primary hover:underline'>GitHub Actions</a
            >
          </li>
          <li>
            Comment system: <a
              href='https://giscus.app'
              target='_blank'
              class='text-primary hover:underline'>Giscus</a
            >
          </li>
        </ul>
      </div>
    </div>
  </div>  

  {/* Hobbies Section */}
  <div
    class='group flex flex-col overflow-hidden rounded-3xl border border-border/40 bg-background/40 backdrop-blur-md shadow-sm transition-all duration-500 hover:-translate-y-1 hover:border-transparent hover:shadow-[0_10px_30px_-10px_var(--primary)] mb-10'
  >
    <div class='p-6 sm:p-8 pt-5 sm:pt-7'>
      <h2 id='hobbies' class='mt-0 mb-6 flex items-center gap-2'>
        <span class='text-2xl'>爱好</span>
      </h2>
      <HobbySection class='mb-5' title='IT' items={['Web3', 'SSG（静态站点生成器）']} />

      <div
        class='mb-4 flex flex-col gap-y-3 sm:gap-y-4 rounded-xl border p-5 bg-muted/10 not-prose'
      >
        <div class='m-0 text-lg font-medium text-foreground flex items-center gap-2'>
          <span class='text-primary'>🎮</span> 游戏
        </div>
        <div class='flex flex-col gap-4'>
          <div>
            <h4 class='mb-2 text-xs font-semibold uppercase tracking-wider text-muted-foreground'>
              竞技
            </h4>
            <div class='flex flex-wrap gap-2'>
              <span
                class='rounded-lg border bg-background/50 px-3 py-1.5 text-sm backdrop-blur-sm transition-all hover:-translate-y-0.5 hover:bg-muted shadow-sm'
                >League of Legends (LOL)</span
              >
              <span
                class='rounded-lg border bg-background/50 px-3 py-1.5 text-sm backdrop-blur-sm transition-all hover:-translate-y-0.5 hover:bg-muted shadow-sm'
                >Overwatch (OW)</span
              >
              <span
                class='rounded-lg border bg-background/50 px-3 py-1.5 text-sm backdrop-blur-sm transition-all hover:-translate-y-0.5 hover:bg-muted shadow-sm'
                >王者荣耀</span
              >
            </div>
          </div>

          <div>
            <h4 class='mb-2 text-xs font-semibold uppercase tracking-wider text-muted-foreground'>
              剧情
            </h4>
            <div class='flex flex-wrap gap-2'>
              <span
                class='rounded-lg border bg-background/50 px-3 py-1.5 text-sm backdrop-blur-sm transition-all hover:-translate-y-0.5 hover:bg-muted shadow-sm'
                >明日方舟</span
              >
              <span
                class='rounded-lg border bg-background/50 px-3 py-1.5 text-sm backdrop-blur-sm transition-all hover:-translate-y-0.5 hover:bg-muted shadow-sm'
                >Detroit: Become Human</span
              >
              <span
                class='rounded-lg border bg-background/50 px-3 py-1.5 text-sm backdrop-blur-sm transition-all hover:-translate-y-0.5 hover:bg-muted shadow-sm'
                >星穹铁道</span
              >
              <span
                class='rounded-lg border bg-background/50 px-3 py-1.5 text-sm backdrop-blur-sm transition-all hover:-translate-y-0.5 hover:bg-muted shadow-sm'
                >黑神话：悟空</span
              >
            </div>
          </div>

          <div>
            <h4 class='mb-2 text-xs font-semibold uppercase tracking-wider text-muted-foreground'>
              单机
            </h4>
            <div class='flex flex-wrap gap-2'>
              <span
                class='rounded-lg border bg-background/50 px-3 py-1.5 text-sm backdrop-blur-sm transition-all hover:-translate-y-0.5 hover:bg-muted shadow-sm'
                >Ghostrunner</span
              >
              <span
                class='rounded-lg border bg-background/50 px-3 py-1.5 text-sm backdrop-blur-sm transition-all hover:-translate-y-0.5 hover:bg-muted shadow-sm'
                >GTA</span
              >
              <span
                class='rounded-lg border bg-background/50 px-3 py-1.5 text-sm backdrop-blur-sm transition-all hover:-translate-y-0.5 hover:bg-muted shadow-sm'
                >荒野大镖客</span
              >
              <span
                class='rounded-lg border bg-background/50 px-3 py-1.5 text-sm backdrop-blur-sm transition-all hover:-translate-y-0.5 hover:bg-muted shadow-sm'
                >泰坦陨落2</span
              >
            </div>
          </div>

          <div>
            <h4 class='mb-2 text-xs font-semibold uppercase tracking-wider text-muted-foreground'>
              音游
            </h4>
            <div class='flex flex-wrap gap-2'>
              <span
                class='rounded-lg border bg-background/50 px-3 py-1.5 text-sm backdrop-blur-sm transition-all hover:-translate-y-0.5 hover:bg-muted shadow-sm'
