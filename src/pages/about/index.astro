              >
              <span
                class='rounded-lg border bg-background/50 px-3 py-1.5 text-sm backdrop-blur-sm transition-all hover:-translate-y-0.5 hover:bg-muted shadow-sm'
                >Bits & Bops</span
              >
            </div>
          </div>

          <div>
            <h4 class='mb-2 text-xs font-semibold uppercase tracking-wider text-muted-foreground'>
              休闲
            </h4>
            <div class='flex flex-wrap gap-2'>
              <span
                class='rounded-lg border bg-background/50 px-3 py-1.5 text-sm backdrop-blur-sm transition-all hover:-translate-y-0.5 hover:bg-muted shadow-sm'
