---
import type { GetStaticPaths, Page } from 'astro'
import type { CollectionEntry } from 'astro:content'

import { Paginator, PostPreview } from 'astro-pure/components/pages'
import { getBlogCollection, getUniqueTags, sortMDByDate } from 'astro-pure/server'
import { Icon } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'
import TagRelations from '@/components/tags/TagRelations.astro'
import { getPostPath } from '@/utils/content-paths'
import config from '@/site-config'

export const prerender = true

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const allPosts = await getBlogCollection()
  const allPostsByDate = sortMDByDate(allPosts)
  const uniqueTags = getUniqueTags(allPostsByDate)

  return uniqueTags.flatMap((tag) => {
    const filterPosts = allPostsByDate.filter((post) => post.data.tags.includes(tag))
    const relatedTagCounts = new Map<string, number>()

    filterPosts.forEach((post) => {
      post.data.tags.forEach((postTag) => {
        if (postTag !== tag) {
          relatedTagCounts.set(postTag, (relatedTagCounts.get(postTag) ?? 0) + 1)
        }
      })
    })

    const relatedTags = [...relatedTagCounts.entries()]
      .sort(
        ([tagA, countA], [tagB, countB]) =>
          countB - countA || tagA.localeCompare(tagB, undefined, { sensitivity: 'base' })
      )
      .slice(0, 10)
      .map(([name, count]) => ({ name, count }))

    const relatedPosts = filterPosts.slice(0, 12).map((post) => ({
      id: post.id,
      href: getPostPath(post as CollectionEntry<'blog'>),
      title: post.data.title,
      tags: post.data.tags
    }))

    return paginate(filterPosts, {
      pageSize: config.content.blogPageSize,
      params: { tag },
      props: { relatedPosts, relatedTags }
    })
  })
}

interface Props {
  page: Page<CollectionEntry<'blog'>>
  relatedPosts: Array<{ id: string; href: string; title: string; tags: string[] }>
  relatedTags: Array<{ name: string; count: number }>
}

const { page, relatedPosts, relatedTags } = Astro.props
const { tag } = Astro.params

const meta = {
  description: `View all posts with the tag - ${tag}`,
  title: `Tag: ${tag}`
}

const paginationProps = {
  ...(page.url.prev && {
    prevUrl: {
      text: `← Newer posts`,
      url: page.url.prev
    }
  }),
  ...(page.url.next && {
    nextUrl: {
      text: `Older posts →`,
      url: page.url.next
    }
  })
}
---

<PageLayout {meta}>
  <main class='tag-detail mt-6 lg:mt-10'>
    <header id='content-header' class='tag-detail__hero animate'>
      <nav aria-label='Breadcrumb' class='tag-detail__breadcrumb'>
        <a href='/tags' data-astro-prefetch>All tags</a>
        <span aria-hidden='true'>/</span>
        <span>{tag}</span>
      </nav>

      <div class='tag-detail__heading'>
        <div class='tag-detail__icon' aria-hidden='true'>
          <Icon name='hashtag' />
        </div>
        <div>
          <span class='tag-detail__label'>Posts tagged with</span>
          <h1>{tag}</h1>
        </div>
      </div>

      <div class='tag-detail__summary'>
        <p>
          <strong>{page.total}</strong>
          {page.total === 1 ? ' post' : ' posts'} in this topic
        </p>
        <span>Page {page.currentPage} of {page.lastPage}</span>
      </div>
    </header>

    <TagRelations tag={tag!} posts={relatedPosts} {relatedTags} />

    <section id='content' class='tag-detail__content animate' aria-label={`Posts tagged ${tag}`}>
      <div class='tag-detail__section-heading'>
        <h2>Latest writing</h2>
        <a href='/tags' data-astro-prefetch>
          Browse all topics <span aria-hidden='true'>↗</span>
        </a>
      </div>
      <ul class='flex flex-col gap-y-4 text-start'>
        {page.data.map((post) => <PostPreview {post} detailed />)}
      </ul>
      <Paginator {...paginationProps} />
    </section>
  </main>

  <style>
    .tag-detail__hero {
      position: relative;
      overflow: hidden;
      padding: clamp(1.1rem, 3vw, 1.65rem);
      border: 1px solid hsl(var(--border));
      border-radius: 1.35rem;
      background:
        radial-gradient(circle at 90% 10%, hsl(var(--primary) / 0.16), transparent 32%),
        hsl(var(--background));
    }

    .tag-detail__hero::after {
      position: absolute;
      right: -0.5rem;
      bottom: -4.25rem;
      color: hsl(var(--primary) / 0.06);
      font-size: 10rem;
      font-weight: 700;
      line-height: 1;
      content: '#';
      pointer-events: none;
    }

    .tag-detail__breadcrumb,
    .tag-detail__heading,
    .tag-detail__summary {
      position: relative;
      z-index: 1;
    }

    .tag-detail__breadcrumb {
      display: flex;
      align-items: center;
      gap: 0.55rem;
      color: hsl(var(--muted-foreground));
      font-size: 0.78rem;
    }

    .tag-detail__breadcrumb a:hover {
      color: hsl(var(--primary));
    }

    .tag-detail__heading {
      display: flex;
      align-items: center;
      gap: 0.8rem;
      margin-top: clamp(1.25rem, 3vw, 2rem);
    }

    .tag-detail__icon {
      display: grid;
      width: clamp(2.65rem, 6vw, 3.4rem);
      height: clamp(2.65rem, 6vw, 3.4rem);
      flex: 0 0 auto;
      place-items: center;
      border: 1px solid hsl(var(--primary) / 0.25);
      border-radius: 0.95rem;
      background: hsl(var(--primary) / 0.1);
      color: hsl(var(--primary));
      font-size: clamp(1.15rem, 3vw, 1.55rem);
    }

    .tag-detail__label {
      color: hsl(var(--muted-foreground));
      font-size: 0.72rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .tag-detail h1 {
      max-width: 44rem;
      margin: 0.1rem 0 0;
      overflow-wrap: anywhere;
      font-size: clamp(1.75rem, 5vw, 2.8rem);
      font-weight: 650;
      letter-spacing: -0.04em;
      line-height: 1;
    }

    .tag-detail__summary {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      margin-top: 1.25rem;
      padding-top: 0.8rem;
      border-top: 1px solid hsl(var(--border) / 0.8);
      color: hsl(var(--muted-foreground));
      font-size: 0.8rem;
    }

    .tag-detail__summary p {
      margin: 0;
    }

    .tag-detail__summary strong {
      color: hsl(var(--foreground));
      font-size: 1rem;
    }

    .tag-detail__content {
      margin-top: 2.75rem;
    }

    .tag-detail__section-heading {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 1rem;
    }

    .tag-detail__section-heading h2 {
      margin: 0;
      font-size: 1.25rem;
      font-weight: 600;
    }

    .tag-detail__section-heading a {
      color: hsl(var(--muted-foreground));
      font-size: 0.8rem;
    }

    .tag-detail__section-heading a:hover {
      color: hsl(var(--primary));
    }

    @media (max-width: 480px) {
      .tag-detail__summary {
        align-items: flex-start;
        flex-direction: column;
        gap: 0.25rem;
      }

      .tag-detail__section-heading {
        align-items: flex-start;
        flex-direction: column;
        gap: 0.4rem;
      }
    }
  </style>
</PageLayout>
