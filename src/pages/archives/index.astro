    }

    @keyframes archive-rocket-flame {
      from {
        opacity: 0.78;
        transform: translateX(-50%) scaleY(0.82) scaleX(0.92);
      }
      to {
        opacity: 0.98;
        transform: translateX(-50%) scaleY(1.15) scaleX(1.06);
      }
    }

    @keyframes rocket-rumble {
      from { transform: translateY(-0.22rem) scale(1.06) translateX(-0.3px); }
      to { transform: translateY(-0.22rem) scale(1.06) translateX(0.3px); }
    }

    @keyframes spark-left {
      0% { opacity: 1; transform: translate(0, 0) scale(1); }
      50% { opacity: 0.8; transform: translate(-4px, 6px) scale(0.7); }
      100% { opacity: 0; transform: translate(-6px, 12px) scale(0.3); }
