    margin-top: 0.1rem;
    color: hsl(var(--muted-foreground));
    font-size: 0.66rem;
  }

  .recent-list a {
    display: flex;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .recent-list time {
    flex: 0 0 auto;
  }

  .health-note,
  .post-description {
    color: hsl(var(--muted-foreground));
    font-size: 0.76rem;
    line-height: 1.6;
  }

  .health-note {
    margin: 1.2rem 0 0;
    padding: 0.7rem;
    border-left: 2px solid hsl(var(--primary) / 0.55);
    background: hsl(var(--primary) / 0.06);
  }

  .post-description {
    margin: 1rem 0 0;
  }

  .open-entry {
    display: flex;
    justify-content: space-between;
    margin-top: 1.25rem;
    padding: 0.65rem 0.75rem;
    border: 1px solid hsl(var(--primary) / 0.25);
    border-radius: 0.75rem;
    color: hsl(var(--primary));
    font-size: 0.78rem;
  }

  .tree-posts {
    margin-top: 2.75rem;
  }

  .section-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

