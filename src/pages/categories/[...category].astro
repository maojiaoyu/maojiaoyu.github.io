---
import type { GetStaticPaths } from 'astro'
import type { CollectionEntry } from 'astro:content'

import { PostPreview } from 'astro-pure/components/pages'
import { getBlogCollection, sortMDByDate } from 'astro-pure/server'
import { Icon } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'
import LinkInsightList from '@/components/categories/LinkInsightList.astro'
import {
  buildCategoryInsights,
  type CategoryInsight,
  type PostInsight
} from '@/utils/category-insights'
import {
  getAllCategories,
  getCategoryLabel,
  getCategorySegments,
  getPostCategory
} from '@/utils/content-paths'

export const prerender = true

interface CategoryPreview {
  path: string
  insight: CategoryInsight
}

interface PostPreviewData {
  id: string
  insight: PostInsight
}

interface Props {
  categoryPosts: CollectionEntry<'blog'>[]
  allCategories: string[]
  categoryPreviews: CategoryPreview[]
  postPreviews: PostPreviewData[]
}

export const getStaticPaths: GetStaticPaths = async () => {
  const posts = sortMDByDate(await getBlogCollection()) as CollectionEntry<'blog'>[]
  const categories = getAllCategories(posts)
  const { insights, postInsights } = await buildCategoryInsights(posts)
  const allCategories = [...categories.keys()]

  return [...categories.entries()].map(([category, categoryPosts]) => {
    const segments = getCategorySegments(category)
    const childCategories = allCategories.filter((path) => {
      const childSegments = getCategorySegments(path)
      return childSegments.length === segments.length + 1 && path.startsWith(`${category}/`)
    })
    const directPosts = categoryPosts.filter((post) => getPostCategory(post) === category)

    return {
      params: { category },
      props: {
        categoryPosts,
        allCategories,
        categoryPreviews: [category, ...childCategories]
          .map((path) => ({ path, insight: insights.get(path) }))
          .filter((entry): entry is CategoryPreview => Boolean(entry.insight)),
        postPreviews: directPosts
          .map((post) => ({ id: post.id, insight: postInsights.get(post.id) }))
          .filter((entry): entry is PostPreviewData => Boolean(entry.insight))
      }
    }
  })
}

const { categoryPosts, allCategories, categoryPreviews, postPreviews } = Astro.props
const category = Astro.params.category!
const segments = getCategorySegments(category)
const currentLabel = getCategoryLabel(segments.at(-1)?.name ?? category)
const parentPath =
  segments.length > 1
    ? segments
        .slice(0, -1)
        .map(({ name }) => name)
        .join('/')
    : undefined
const currentDepth = segments.length
const siblingCategories = allCategories
  .filter((path) => {
    const candidate = getCategorySegments(path)
    if (candidate.length !== currentDepth) return false
    const candidateParent = candidate
      .slice(0, -1)
      .map(({ name }) => name)
      .join('/')
    return candidateParent === (parentPath ?? '')
  })
  .sort((a, b) => a.localeCompare(b))
const childCategories = allCategories
  .filter((path) => {
    const childSegments = getCategorySegments(path)
    return childSegments.length === currentDepth + 1 && path.startsWith(`${category}/`)
  })
  .sort((a, b) => a.localeCompare(b))
const directPosts = categoryPosts.filter((post) => getPostCategory(post) === category)
const currentInsight = categoryPreviews.find(({ path }) => path === category)!.insight
const categoryPreviewMap = new Map(categoryPreviews.map(({ path, insight }) => [path, insight]))
const postPreviewMap = new Map(postPreviews.map(({ id, insight }) => [id, insight]))
const defaultPreviewKey = `category:${category}`

const formatDate = (date: string) =>
  new Intl.DateTimeFormat('zh-CN', {
    year: 'numeric',
    month: 'short',
    day: 'numeric'
  }).format(new Date(date))

const meta = {
  title: `Category: ${currentLabel}`,
  description: `Browse posts filed under ${currentLabel}`
}
---

<PageLayout {meta}>
  <main class='category-detail mt-6 lg:mt-10'>
    <header id='content-header' class='detail-hero animate'>
      <nav aria-label='Breadcrumb'>
        <a href='/categories'>分类</a>
        {
          segments.map((segment, index) => (
            <>
              <span aria-hidden='true'>/</span>
              {index === segments.length - 1 ? (
                <span>{getCategoryLabel(segment.name)}</span>
              ) : (
                <a href={`/categories/${segment.path}`}>{getCategoryLabel(segment.name)}</a>
              )}
            </>
          ))
        }
      </nav>

      <div class='detail-title'>
        <span><Icon name='package' /></span>
        <div>
          <small>Knowledge folder</small>
          <h1>{currentLabel}</h1>
        </div>
      </div>

      <p>
        目录用于稳定归档，标签和双向链接负责跨目录建立关系。按 Enter 打开，按
        Backspace 返回上级。
      </p>
    </header>

    <section
      id='content'
      class='miller-browser animate'
      aria-label={`${currentLabel} 分类浏览器`}
      data-category-browser
      data-parent-href={parentPath ? `/categories/${parentPath}` : '/categories'}
    >
      <div class='browser-column browser-context' data-browser-column>
        <header>
          <span>位置</span>
          <small>{currentDepth} 层</small>
        </header>
        <div class='browser-list'>
          <a
            class='browser-row browser-up'
            href={parentPath ? `/categories/${parentPath}` : '/categories'}
            data-browser-item
          >
            <span class='row-icon'>↑</span>
            <span>
              <strong
                >{parentPath ? getCategoryLabel(parentPath.split('/').at(-1)!) : '全部分类'}</strong
              >
              <small>上级目录</small>
            </span>
          </a>
          {
            siblingCategories.map((path) => {
              const isCurrent = path === category
              return (
                <a
                  class:list={['browser-row', { 'is-current': isCurrent }]}
                  href={`/categories/${path}`}
                  aria-current={isCurrent ? 'page' : undefined}
                  data-browser-item
                  data-preview-key={isCurrent ? defaultPreviewKey : undefined}
                >
                  <span class='row-icon'>
                    <Icon name='package' />
                  </span>
                  <span>
                    <strong>{getCategoryLabel(path.split('/').at(-1)!)}</strong>
                    <small>{isCurrent ? '当前目录' : '同级目录'}</small>
                  </span>
                </a>
              )
            })
          }
        </div>
      </div>

      <div class='browser-column browser-contents' data-browser-column>
        <header>
          <span>内容</span>
          <small>{childCategories.length} 目录 · {directPosts.length} 文章</small>
        </header>
        <div class='browser-list'>
          {
            childCategories.map((path) => {
              const insight = categoryPreviewMap.get(path)!
              return (
                <a
                  class='browser-row'
                  href={`/categories/${path}`}
                  data-browser-item
                  data-preview-key={`category:${path}`}
                >
                  <span class='row-icon'>
                    <Icon name='package' />
                  </span>
                  <span>
                    <strong>{getCategoryLabel(path.split('/').at(-1)!)}</strong>
                    <small>
                      {insight.totalPosts} 篇 · {insight.childCategories} 个子目录
                    </small>
                  </span>
                  <span aria-hidden='true'>›</span>
                </a>
              )
            })
          }
          {
            directPosts.map((post) => {
              const insight = postPreviewMap.get(post.id)!
              return (
                <a
                  class='browser-row'
                  href={insight.href}
                  data-browser-item
                  data-preview-key={`post:${post.id}`}
                >
                  <span class='row-icon'>
                    <Icon name='document' />
                  </span>
                  <span>
                    <strong>{insight.title}</strong>
                    <small>{formatDate(insight.date)}</small>
                  </span>
                </a>
              )
            })
          }
          {
            childCategories.length === 0 && directPosts.length === 0 && (
              <p class='browser-empty'>当前目录没有直接内容。</p>
            )
          }
        </div>
      </div>

      <aside class='browser-column browser-preview' aria-live='polite'>
        <header>
          <span>预览</span>
          <small>关系与统计</small>
        </header>
        {
          categoryPreviews.map(({ path, insight }) => (
            <article
              class='preview-panel'
              data-preview-panel={`category:${path}`}
              hidden={path !== category}
            >
              <div class='preview-heading'>
                <span>
                  <Icon name='package' />
                </span>
                <div>
                  <small>目录</small>
                  <h2>{insight.label}</h2>
                </div>
              </div>

              <dl class='stats-grid'>
                <div>
                  <>
                    <dt>全部文章</dt>
                    <dd>{insight.totalPosts}</dd>
                  </>
                </div>
                <div>
                  <>
                    <dt>直接文章</dt>
                    <dd>{insight.directPosts}</dd>
                  </>
                </div>
                <div>
                  <>
                    <dt>入链</dt>
                    <dd>{insight.inboundLinks}</dd>
                  </>
                </div>
                <div>
                  <>
                    <dt>出链</dt>
                    <dd>{insight.outboundLinks}</dd>
                  </>
                </div>
              </dl>
              <LinkInsightList
                inbound={insight.inboundLinkDetails}
                outbound={insight.outboundLinkDetails}
              />

              {insight.topTags.length > 0 && (
                <section class='preview-section'>
                  <h3>主要标签</h3>
                  <div class='tag-cloud'>
                    {insight.topTags.map(({ name, count }) => (
                      <a href={`/tags/${name}`}>
                        #{name}
                        <span>{count}</span>
                      </a>
                    ))}
                  </div>
                </section>
              )}

              {insight.relatedCategories.length > 0 && (
                <section class='preview-section'>
                  <h3>相关目录</h3>
                  <ul class='relation-list'>
                    {insight.relatedCategories.map((related) => (
                      <li>
                        <a href={`/categories/${related.path}`}>
                          <strong>{related.label}</strong>
                          <small>
                            {related.crossLinks > 0 && `${related.crossLinks} 条跨目录链接`}
                            {related.crossLinks > 0 && related.sharedTags.length > 0 && ' · '}
                            {related.sharedTags.length > 0 &&
                              `${related.sharedTags.length} 个共同标签`}
                          </small>
                        </a>
                      </li>
                    ))}
                  </ul>
                </section>
              )}

              {insight.recentPosts.length > 0 && (
                <section class='preview-section'>
                  <h3>最近更新</h3>
                  <ul class='recent-list'>
                    {insight.recentPosts.slice(0, 3).map((post) => (
                      <li>
                        <a href={post.href}>
                          <span>{post.title}</span>
                          <time datetime={post.date}>{formatDate(post.date)}</time>
                        </a>
                      </li>
                    ))}
                  </ul>
                </section>
              )}

              {insight.orphanPosts > 0 && (
                <p class='health-note'>
                  {insight.orphanPosts} 篇文章尚无入链或出链，可作为后续整理提示。
                </p>
              )}
            </article>
          ))
        }

        {
          postPreviews.map(({ id, insight }) => (
            <article class='preview-panel' data-preview-panel={`post:${id}`} hidden>
              <div class='preview-heading'>
                <span>
                  <Icon name='document' />
                </span>
                <div>
                  <small>文章</small>
                  <h2>{insight.title}</h2>
                </div>
              </div>
              <p class='post-description'>{insight.description}</p>
              <dl class='stats-grid'>
                <div>
                  <>
                    <dt>入链</dt>
                    <dd>{insight.inboundLinks}</dd>
                  </>
                </div>
                <div>
                  <>
                    <dt>出链</dt>
                    <dd>{insight.outboundLinks}</dd>
                  </>
                </div>
                <div class='wide-stat'>
                  <>
                    <dt>更新</dt>
                    <dd>{formatDate(insight.date)}</dd>
                  </>
                </div>
              </dl>
              <LinkInsightList
                inbound={insight.inboundLinkDetails}
                outbound={insight.outboundLinkDetails}
              />
              {insight.tags.length > 0 && (
                <section class='preview-section'>
                  <h3>标签</h3>
                  <div class='tag-cloud'>
                    {insight.tags.map((tag) => (
                      <a href={`/tags/${tag}`}>#{tag}</a>
                    ))}
                  </div>
                </section>
              )}
              <a class='open-entry' href={insight.href}>
                打开文章 <span aria-hidden='true'>→</span>
              </a>
            </article>
          ))
        }
      </aside>
    </section>

    <section class='tree-posts animate' aria-labelledby='tree-posts-title'>
      <div class='section-heading'>
        <div>
          <h2 id='tree-posts-title'>目录树中的全部文章</h2>
          <p>包含当前目录及所有子目录，共 {currentInsight.totalPosts} 篇。</p>
        </div>
        <a href='/tags'>按标签浏览 ↗</a>
      </div>
      <ul class='flex flex-col gap-y-4 text-start'>
        {categoryPosts.map((post) => <PostPreview {post} detailed />)}
      </ul>
    </section>
  </main>
</PageLayout>

<script>
  let backNavigationController: AbortController | undefined

  function initializeCategoryBrowser() {
    const browsers = [...document.querySelectorAll<HTMLElement>('[data-category-browser]')]
    if (browsers.length === 0) return

    backNavigationController?.abort()
    backNavigationController = new AbortController()

    browsers.forEach((browser) => {
      if (browser.dataset.initialized === 'true') return
      browser.dataset.initialized = 'true'

      const items = [...browser.querySelectorAll<HTMLElement>('[data-browser-item]')]
      const panels = [...browser.querySelectorAll<HTMLElement>('[data-preview-panel]')]
      let previewTimeout: number | undefined

      const showPreview = (item: HTMLElement, immediate = false) => {
        const key = item.dataset.previewKey
        if (!key) return

        const update = () => {
          items.forEach((candidate) =>
            candidate.classList.toggle('is-previewing', candidate === item)
          )
          panels.forEach((panel) => {
            panel.hidden = panel.dataset.previewPanel !== key
          })
        }

        if (immediate) {
          clearTimeout(previewTimeout)
          update()
        } else {
          clearTimeout(previewTimeout)
          previewTimeout = window.setTimeout(update, 150)
        }
      }

      items.forEach((item) => {
        item.addEventListener('focus', () => showPreview(item, true))
        item.addEventListener('mouseenter', () => showPreview(item))
        item.addEventListener('mouseleave', () => clearTimeout(previewTimeout))
        })
        })

        document.addEventListener(

      'keydown',
      (event) => {
        const target = event.target
        if (
          event.key !== 'Backspace' ||
          (target instanceof HTMLElement &&
            (target.isContentEditable || ['INPUT', 'TEXTAREA'].includes(target.tagName)))
        ) {
          return
        }
        event.preventDefault()
        const browsers = [...document.querySelectorAll<HTMLElement>('[data-category-browser]')]
        if (browsers.length > 0) {
          window.location.href = browsers[0].dataset.parentHref ?? '/categories'
        }
      },
      { signal: backNavigationController.signal }
    )
  }

  document.addEventListener('astro:page-load', initializeCategoryBrowser)
  initializeCategoryBrowser()
</script>

<style>
  .detail-hero {
    padding: clamp(1.2rem, 3vw, 2rem);
    border: 1px solid hsl(var(--border));
    border-radius: 1.4rem;
    background:
      radial-gradient(circle at 90% 0%, hsl(var(--primary) / 0.15), transparent 32%),
      hsl(var(--background));
  }

  .detail-hero nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    color: hsl(var(--muted-foreground));
    font-size: 0.78rem;
  }

  .detail-hero nav a:hover,
  .section-heading a:hover {
    color: hsl(var(--primary));
  }

  .detail-title {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    margin-top: 1.5rem;
  }

  .detail-title > span,
  .preview-heading > span {
    display: grid;
    place-items: center;
    background: hsl(var(--primary) / 0.1);
    color: hsl(var(--primary));
  }

  .detail-title > span {
    width: 3.25rem;
    height: 3.25rem;
    border-radius: 1rem;
    font-size: 1.4rem;
  }

  .detail-title small,
  .preview-heading small {
    color: hsl(var(--muted-foreground));
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0.1rem 0 0;
    font-size: clamp(2rem, 6vw, 3.5rem);
    letter-spacing: -0.045em;
    line-height: 1;
  }

  .detail-hero > p {
    max-width: 48rem;
    margin: 1.25rem 0 0;
    color: hsl(var(--muted-foreground));
  }

  .miller-browser {
    display: grid;
    grid-template-columns: minmax(10rem, 0.7fr) minmax(15rem, 1fr) minmax(18rem, 1.25fr);
    min-height: 35rem;
    margin-top: 2rem;
    overflow: hidden;
    border: 1px solid hsl(var(--border));
    border-radius: 1.35rem;
    background: hsl(var(--background) / 0.78);
    box-shadow: 0 1.25rem 3rem hsl(var(--foreground) / 0.05);
  }

  .browser-column {
    min-width: 0;
  }

  .browser-column + .browser-column {
    border-left: 1px solid hsl(var(--border));
  }

  .browser-column > header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 2.8rem;
    padding: 0.75rem 0.9rem;
    border-bottom: 1px solid hsl(var(--border));
    background: hsl(var(--muted) / 0.45);
    font-size: 0.75rem;
    font-weight: 650;
  }

  .browser-column > header small {
    color: hsl(var(--muted-foreground));
    font-weight: 400;
  }

  .browser-list {
    padding: 0.45rem;
  }

  .browser-row {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.65rem;
    padding: 0.7rem;
    border-radius: 0.7rem;
    outline: none;
    transition:
      color 120ms ease,
      background 120ms ease;
  }

  .browser-row:hover,
  .browser-row:focus-visible,
  .browser-row.is-previewing {
    background: hsl(var(--primary) / 0.1);
    color: hsl(var(--primary));
  }

  .browser-row.is-current {
    background: hsl(var(--primary) / 0.12);
  }

  .browser-row strong,
  .browser-row small {
    display: block;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .browser-row strong {
    font-size: 0.84rem;
    font-weight: 580;
  }

  .browser-row small {
    margin-top: 0.1rem;
    color: hsl(var(--muted-foreground));
    font-size: 0.67rem;
  }

  .row-icon {
    display: grid;
    width: 1.35rem;
    height: 1.35rem;
    place-items: center;
    color: hsl(var(--muted-foreground));
  }

  .browser-row:hover .row-icon,
  .browser-row:focus-visible .row-icon,
  .browser-row.is-previewing .row-icon {
    color: hsl(var(--primary));
  }

  .browser-empty {
