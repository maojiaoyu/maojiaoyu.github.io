    padding: 1.25rem 0.75rem;
    color: hsl(var(--muted-foreground));
    font-size: 0.8rem;
  }

  .browser-preview {
    background:
      radial-gradient(circle at 100% 0%, hsl(var(--primary) / 0.09), transparent 40%),
      hsl(var(--background));
  }

  .preview-panel {
    padding: 1.25rem;
  }

  .preview-heading {
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .preview-heading > span {
    flex: 0 0 auto;
    width: 2.6rem;
    height: 2.6rem;
    border-radius: 0.8rem;
  }

  .preview-heading h2 {
    margin: 0.1rem 0 0;
    font-size: 1.25rem;
    line-height: 1.2;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.55rem;
    margin: 1.2rem 0 0;
  }

  .stats-grid > div {
    padding: 0.7rem;
    border: 1px solid hsl(var(--border));
    border-radius: 0.75rem;
    background: hsl(var(--muted) / 0.3);
  }

  .stats-grid dt {
    color: hsl(var(--muted-foreground));
    font-size: 0.66rem;
  }

  .stats-grid dd {
    margin: 0.15rem 0 0;
    font-size: 1.15rem;
    font-weight: 650;
  }

  .stats-grid .wide-stat {
    grid-column: 1 / -1;
  }

  .wide-stat dd {
    font-size: 0.9rem;
  }

  .preview-section {
    margin-top: 1.25rem;
  }

  .preview-section h3 {
    margin: 0 0 0.55rem;
    color: hsl(var(--muted-foreground));
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag-cloud a {
    display: inline-flex;
    gap: 0.35rem;
    padding: 0.28rem 0.55rem;
    border-radius: 999px;
    background: hsl(var(--muted) / 0.75);
    font-size: 0.7rem;
  }

  .tag-cloud a:hover {
    color: hsl(var(--primary));
  }

  .tag-cloud span {
    color: hsl(var(--muted-foreground));
  }

  .relation-list,
  .recent-list {
    margin: 0;
    padding: 0;
