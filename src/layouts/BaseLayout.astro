---
import { Footer, ThemeProvider } from 'astro-pure/components/basic'
import type { SiteMeta } from 'astro-pure/types'
import BaseHead from '@/components/BaseHead.astro'
import CategoryBrowserOverlay from '@/components/categories/CategoryBrowserOverlay.astro'
import CustomHeader from '@/components/CustomHeader.astro'
import TagCloudOverlay from '@/components/tags/TagCloudOverlay.astro'
import KnowledgeGraph from '@/components/graph/KnowledgeGraph.astro'
import PageTransition from '@/components/PageTransition.astro'
import config from '@/site-config'

// Import the global.css file here so that it is included on
// all pages through the use of the <BaseLayout /> component.
import '@/assets/styles/global.css'
import '@/assets/styles/app.css'

interface Props {
  meta: SiteMeta
  highlightColor?: string
}

const {
  meta: { articleDate, description = config.description, ogImage, title },
  highlightColor = '#B19CD9',
  ...props
} = Astro.props
---

<html lang={config.locale.lang} class='overflow-y-scroll' transition:animate='none'>
  <head>
    <BaseHead {articleDate} {description} {ogImage} {title} />
    <!-- bing站长验证 -->
    <meta name="msvalidate.01" content="9035FA14883802C6052D7EE6FCD7731F" />
    <!-- baidu站长验证 -->
    <meta name="baidu-site-verification" content="codeva-L4XnN2zqmf" />
    <!-- 增加Clarity分析 -->
    <script type="text/javascript">
      (function(c,l,a,r,i,t,y){
          c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
         t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
          y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "xmtano8vjy");
    </script>
    <ThemeProvider />
    <PageTransition />
  </head>

  <body class='bg-background text-foreground' {...props}>
    <div
      id='highlight-gradient'
      class='pointer-events-none absolute start-0 top-0 z-0 h-screen w-full opacity-25'
      style={`background-image:linear-gradient(${highlightColor},transparent)`}
    >
    </div>
    <div
      id='main-container'
      class='mx-auto w-full max-w-[70rem] min-h-[100dvh] flex flex-col justify-between'
    >
      <CustomHeader />
      <div id='page-content' class='flex-1 w-full' data-page-content>
        <slot />
      </div>
      <Footer />
    </div>
    <CategoryBrowserOverlay />
    <KnowledgeGraph />
    <TagCloudOverlay />
    <slot name='overlay' />

    {/* Set highlight color */}
    <style define:vars={{ highlightColor }}>
      :global(.highlight) {
        --highlight-fg: color-mix(
          in srgb,
          var(--highlightColor) 40%,
          hsl(var(--foreground)/var(--un-text-opacity, 1))
        );
        color: var(--highlight-fg, hsl(var(--primary) / var(--un-text-opacity))) !important;
      }
      :global(.highlight-bg) {
        background-color: var(
          --highlightColor,
          hsl(var(--primary) / var(--un-text-opacity))
        ) !important;
      }

      /* Extend safe area for some special screens
       * https://developer.mozilla.org/en-US/docs/Web/CSS/Reference/Values/env
       * https://webkit.org/blog/7929/designing-websites-for-iphone-x/
       */
      #main-container {
        padding-top: env(safe-area-inset-top);
        padding-left: calc(1rem + env(safe-area-inset-left));
        padding-right: calc(1rem + env(safe-area-inset-right));
      }
      @media (min-width: 640px) {
        #main-container {
          padding-left: calc(1.75rem + env(safe-area-inset-left));
          padding-right: calc(1.75rem + env(safe-area-inset-right));
        }
      }
      @media (min-width: 1024px) {
        #main-container {
          padding-left: calc(2.5rem + env(safe-area-inset-left));
          padding-right: calc(2.5rem + env(safe-area-inset-right));
        }
      }

      :global([data-page-content].is-page-entering) {
        animation: page-content-enter 160ms ease-out backwards;
      }

      @keyframes page-content-enter {
        from {
          opacity: 0;
          translate: 0 4px;
        }
        to {
          opacity: 1;
          translate: none;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        :global([data-page-content].is-page-entering) {
          animation: none;
        }
      }
    </style>

    <script>
      function animatePageContent() {
        const content = document.querySelector<HTMLElement>('[data-page-content]')
        if (!content) return
        content.classList.remove('is-page-entering')
        void content.offsetWidth
        content.classList.add('is-page-entering')
      }

      animatePageContent()
      document.addEventListener('astro:page-load', animatePageContent)
    </script>
  </body>
</html>
